# Copy to .env and fill in. All values are optional except GEMINI_API_KEY for OCR.

# Server
PORT=3000
NODE_ENV=development
# Secret used to sign session cookies. CHANGE THIS in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Default admin account seeded on first run (only if no users exist yet).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# Gemini (Google AI Studio) — https://aistudio.google.com/apikey
# If unset, receipt OCR is disabled (uploads + manual entry still work).
GEMINI_API_KEY=
# Model that supports vision + JSON mode. Override if you have access to newer.
GEMINI_MODEL=gemini-2.5-flash

# Where receipts are stored (relative to project root). Created at runtime.
RECEIPTS_DIR=data/receipts
DB_PATH=data/app.db

# Outward-facing URL (used to build password-reset links). Set to your real URL
# in production, e.g. https://expenses.example.com
APP_BASE_URL=http://localhost:3000

# Email (SMTP) for password-reset links — all optional. If SMTP_HOST is unset,
# reset links are shown to the admin to copy instead of being emailed.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false        # true for 465 (TLS), false for 587 (STARTTLS)
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=OpenExpense <no-reply@example.com>
