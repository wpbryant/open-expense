<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reset password · <%= appName %></title>
  <meta name="theme-color" content="#2563eb" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" href="/icons/favicon-32.png?v=<%= assetVersion %>" />
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <div class="auth-wrap">
    <div class="card auth-card">
      <img class="auth-logo" src="/icons/icon-192.png?v=<%= assetVersion %>" alt="" width="48" height="48" />
      <h1>Reset password</h1>

      <% if (done) { %>
        <p class="sub">Your password has been updated.</p>
        <div class="flash flash-success">Password changed. You can now <a href="/login">sign in</a>.</div>
        <a class="btn btn-primary" href="/login" style="width:100%; justify-content:center;">Go to sign in</a>
      <% } else if (invalid) { %>
        <p class="sub">OpenExpense</p>
        <div class="flash flash-error">
          This reset link is invalid or has expired. Ask an administrator to send you a new one.
        </div>
        <a class="btn" href="/login" style="width:100%; justify-content:center;">Back to sign in</a>
      <% } else { %>
        <% if (typeof user !== 'undefined' && user) { %>
          <p class="sub">Set a new password for <strong><%= user.username %></strong></p>
        <% } else { %>
          <p class="sub">Set a new password</p>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flash flash-error"><%= error %></div>
        <% } %>

        <form method="post" action="/reset-password">
          <input type="hidden" name="token" value="<%= token %>" />
          <div class="field">
            <label for="password">New password</label>
            <input id="password" name="password" type="password" autocomplete="new-password" required minlength="6" autofocus />
          </div>
          <div class="field">
            <label for="confirm">Confirm password</label>
            <input id="confirm" name="confirm" type="password" autocomplete="new-password" required minlength="6" />
          </div>
          <button class="btn btn-primary" type="submit" style="width:100%; justify-content:center;">Set new password</button>
        </form>
      <% } %>
    </div>
  </div>
</body>
</html>
